# ====================================================
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=VOTRE_TOKEN_TELEGRAM_ICI

# Comma-separated Telegram numeric user IDs allowed to use the panel.
# Get your ID from @userinfobot. The FIRST id listed is treated as the
# primary owner (gets owner-only commands like broadcast/shutdown).
TELEGRAM_OWNER_IDS=VOTRE_ID_TELEGRAM_ICI

# ====================================================
# 🌸 PRETTY GIRL MD - WHATSAPP BOT
# ====================================================
# Comma-separated WhatsApp numbers (digits only, with country code,
# no + or spaces) that get owner-level commands inside WhatsApp chats.
WA_OWNER_NUMBERS=18095120668

# Display name used when requesting pairing codes / browser identification
BOT_NAME=PRETTY GIRL MD

# ====================================================
# 🌸 PRETTY GIRL MD - GENERAL
# ====================================================
# Max number of simultaneous WhatsApp sessions the panel will manage.
MAX_SESSIONS=5

# ====================================================
# 🌸 PRETTY GIRL MD - OPTIONS
# ====================================================
# Bot version
BOT_VERSION=5.0.0

# Creator credit
CREATOR=DEV SHADOW TECH